# CI=true makes Create React App treat ESLint warnings as build-breaking errors.
# Vercel sets CI=true automatically. This flag prevents that escalation so that
# a stray unused-import warning never blocks a deploy — warnings still show in
# the build log, they just don't fail the build.
CI=false

# Keep source maps off in production to slightly speed up the build and avoid
# shipping unminified source alongside the bundle.
GENERATE_SOURCEMAP=false
